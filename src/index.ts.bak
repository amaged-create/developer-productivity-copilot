export interface Env {
	AI: Ai;
}

function json(data: unknown, status = 200): Response {
	return new Response(JSON.stringify(data, null, 2), {
		status,
		headers: {
			"content-type": "application/json",
			"access-control-allow-origin": "*",
			"access-control-allow-methods": "GET, POST, OPTIONS",
			"access-control-allow-headers": "content-type",
		},
	});
}

function html(): Response {
	return new Response(
		`<!doctype html>
<html>
<head>
	<title>Manufacturing Copilot</title>
	<style>
		body {
			font-family: Arial, sans-serif;
			max-width: 850px;
			margin: 40px auto;
			padding: 0 20px;
			background: #f7f7f7;
		}
		.card {
			background: white;
			padding: 24px;
			border-radius: 12px;
			box-shadow: 0 2px 12px rgba(0,0,0,.08);
		}
		textarea {
			width: 100%;
			height: 100px;
			font-size: 16px;
			padding: 12px;
			box-sizing: border-box;
		}
		button {
			margin-top: 12px;
			padding: 12px 18px;
			font-size: 16px;
			cursor: pointer;
		}
		pre {
			background: #111;
			color: #eee;
			padding: 16px;
			white-space: pre-wrap;
			border-radius: 8px;
			min-height: 120px;
		}
		.small {
			color: #666;
			font-size: 14px;
		}
	</style>
</head>
<body>
	<div class="card">
		<h1>Manufacturing Copilot</h1>
		<p class="small">Demo 1: Cloudflare Workers + Workers AI</p>

		<textarea id="q">Why was Line 2 delayed and what should the quality team check?</textarea>
		<br />
		<button onclick="ask()">Ask Copilot</button>

		<h3>Response</h3>
		<pre id="out">Ready.</pre>
	</div>

<script>
async function ask() {
	const question = document.getElementById("q").value;
	document.getElementById("out").textContent = "Thinking...";

	const res = await fetch("/api/ask", {
		method: "POST",
		headers: { "content-type": "application/json" },
		body: JSON.stringify({ question })
	});

	const data = await res.json();
	document.getElementById("out").textContent = data.answer || JSON.stringify(data, null, 2);
}
</script>
</body>
</html>`,
		{ headers: { "content-type": "text/html" } }
	);
}

async function handleAsk(request: Request, env: Env): Promise<Response> {
	let body: { question?: string };

	try {
		body = await request.json();
	} catch {
		return json({ error: "Invalid JSON body" }, 400);
	}

	const question = body.question?.trim();

	if (!question) {
		return json({ error: "Missing question" }, 400);
	}

	const prompt = `
You are a manufacturing operations copilot.

Answer the user's question in a practical way.
If you do not have enough information, say what data would be needed.
Be concise and operationally focused.

User question:
${question}
`;

	const result = await env.AI.run("@cf/meta/llama-3.1-8b-instruct-fast", {
		prompt,
	});

	const anyResult = result as any;
	const answer = anyResult.response || anyResult.result?.response || JSON.stringify(result);

	return json({
		question,
		answer,
		architecture: {
			compute: "Cloudflare Workers",
			ai: "Workers AI",
		},
	});
}

export default {
	async fetch(request: Request, env: Env): Promise<Response> {
		const url = new URL(request.url);

		if (request.method === "OPTIONS") {
			return json({});
		}

		if (url.pathname === "/") {
			return html();
		}

		if (url.pathname === "/api/ask" && request.method === "POST") {
			return handleAsk(request, env);
		}

		if (url.pathname === "/api/health") {
			return json({
				status: "ok",
				service: "manufacturing-copilot",
			});
		}

		return json({ error: "Not found" }, 404);
	},
} satisfies ExportedHandler<Env>;
